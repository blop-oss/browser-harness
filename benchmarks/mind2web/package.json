{
  "name": "@blopai/mind2web-benchmark",
  "private": true,
  "type": "module",
  "description": "Agent-neutral live Mind2Web benchmark for @blopai/browser-harness.",
  "scripts": {
    "bench:blop": "blop test adapters/blop.blop.ts --report-dir .mind2web/blop --reporter all",
    "bench:blop:headed": "blop test adapters/blop.blop.ts --report-dir .mind2web/blop --capture-screenshots --headed",
    "bench:list": "blop list adapters/blop.blop.ts"
  },
  "devDependencies": {
    "@blopai/cli": "^1.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
